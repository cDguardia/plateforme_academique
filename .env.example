# ─── Sécurité ────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_use_long_random_string

# ─── Base de données ─────────────────────────────────────────
DATABASE_URL=mysql+pymysql://academique:academique@db:3306/academique

# ─── Session ─────────────────────────────────────────────────
# Mettre true uniquement si HTTPS est activé
SESSION_COOKIE_SECURE=false
SESSION_LIFETIME_MINUTES=30

# ─── Environnement Flask ─────────────────────────────────────
# development | production | testing
FLASK_ENV=production
